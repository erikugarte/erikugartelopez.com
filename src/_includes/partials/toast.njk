{%- if toast.active %}
<div class="toast-aviso" id="toastAviso" role="status" aria-live="polite">
  <span class="toast-aviso__dot"></span>
  <p class="toast-aviso__text">{{ toast.text | safe }}</p>
  {% if toast.link_url %}
  <a href="{{ toast.link_url }}" class="toast-aviso__link" target="_blank" rel="noopener">{{ toast.link_text }}</a>
  {% endif %}
  <button class="toast-aviso__close" onclick="cerrarToast()" aria-label="Cerrar">&times;</button>
</div>

<style>
  .toast-aviso {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    left: auto;
    transform: translateY(calc(100% + 2rem));
    background: #2c2416;
    color: #f5f0e6;
    padding: 0.85rem 1.3rem;
    border-radius: 3px;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    box-shadow: 0 6px 25px rgba(44, 36, 22, 0.25);
    z-index: 900;
    max-width: 520px;
    opacity: 0;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    font-family: inherit;
  }
  .toast-aviso--visible {
    transform: translateY(0);
    opacity: 1;
  }
  .toast-aviso--saliendo {
    transform: translateY(calc(100% + 2rem));
    opacity: 0;
  }
  .toast-aviso__dot {
    width: 7px;
    height: 7px;
    background: #c9a227;
    border-radius: 50%;
    flex-shrink: 0;
    animation: toast-pulso 2.5s ease-in-out infinite;
  }
  @keyframes toast-pulso {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .toast-aviso__text {
    font-size: 0.88rem;
    line-height: 1.45;
    margin: 0;
    flex: 1;
  }
  .toast-aviso__text em {
    font-style: italic;
  }
  .toast-aviso__link {
    font-size: 0.78rem;
    color: #d4b55a;
    text-decoration: none;
    border-bottom: 1px solid rgba(201, 162, 39, 0.35);
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.2s;
  }
  .toast-aviso__link:hover {
    border-color: #d4b55a;
  }
  .toast-aviso__close {
    background: none;
    border: none;
    color: #f5f0e6;
    opacity: 0.35;
    cursor: pointer;
    font-size: 1.15rem;
    padding: 0.15rem;
    transition: opacity 0.2s;
    flex-shrink: 0;
    line-height: 1;
  }
  .toast-aviso__close:hover {
    opacity: 1;
  }
  @media (max-width: 480px) {
    .toast-aviso {
      right: 0.75rem;
      left: 0.75rem;
      max-width: none;
      padding: 0.75rem 1rem;
      gap: 0.7rem;
    }
    .toast-aviso__text { font-size: 0.82rem; }
  }
</style>

<script>
  (function() {
    var TOAST_ID = '{{ toast.id }}';
    var KEY = 'toast_visto_' + TOAST_ID;

    if (localStorage.getItem(KEY)) return;

    var el = document.getElementById('toastAviso');
    if (!el) return;

    setTimeout(function() {
      el.classList.add('toast-aviso--visible');
    }, 1200);

    window.cerrarToast = function() {
      el.classList.remove('toast-aviso--visible');
      el.classList.add('toast-aviso--saliendo');
      localStorage.setItem(KEY, '1');
      setTimeout(function() {
        el.remove();
      }, 600);
    };

    // Auto-cerrar tras 12 segundos si no interactúa
    setTimeout(function() {
      if (el && el.classList.contains('toast-aviso--visible')) {
        cerrarToast();
      }
    }, 12000);
  })();
</script>
{%- endif %}
